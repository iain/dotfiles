[include]
  path = ~/.config/git/config.local
[user]
  useConfigOnly = true
[push]
  default = current
  followTags = true
  autoSetupRemote = true
[fetch]
  prune = true
  pruneTags = true
  fsckObjects = true
[pull]
  rebase = true
[rebase]
  autostash = true
[branch]
  autosetuprebase = always
  sort = -committerdate
[pager]
  branch = false
[tag]
  gpgSign = true
[core]
  protectNTFS = true
  protectHFS = true
  pager = delta
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  hyperlinks = true
[gpg]
  format = ssh
[gpg "ssh"]
  allowedSignersFile = ~/.config/git/allowed_signers
[transfer]
  fsckObjects = true
[receive]
  fsckObjects = true
[init]
  defaultBranch = main
[rerere]
  enabled = true
[diff]
  algorithm = histogram
  colorMoved = plain
  renames = true
  renameLimit = 5000
[difftool "difftastic"]
  cmd = difft "$LOCAL" "$REMOTE"
[merge]
  conflictStyle = zdiff3
[log]
  date = iso
[help]
  autocorrect = prompt
[column]
  ui = auto
[alias]
  lg = log --oneline --graph --decorate
  uncommit = reset --soft HEAD~1
  amend = commit --amend --no-edit
  difft = difftool --tool=difftastic --no-prompt
  dlog = -c diff.external=difft log -p --ext-diff
  dshow = -c diff.external=difft show --ext-diff
  recent = branch --sort=-committerdate --no-column --format="%(color:dim)%(committerdate:relative)%(color:reset)%09%(refname:short)"
  cleanup = "!git-cleanup"
[credential]
  helper = osxkeychain
[commit]
  gpgSign = true
  verbose = true
[credential "https://github.com"]
  helper =
  helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
  helper =
  helper = !/opt/homebrew/bin/gh auth git-credential
